# ============================================
# PsCielo - Environment Variables
# Copy to .env and configure for your environment
# ============================================

# Application
APP_NAME=PsCielo
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development

# Database - PostgreSQL
DATABASE_URL=postgresql://pscielo:pscielo_dev_password@postgres:5432/pscielo_dev
SQLALCHEMY_ECHO=false

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_EXPIRY=3600

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000","http://control.pscielo.com"]

# Email - SendGrid
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@pscielo.com
SENDGRID_FROM_NAME=PsCielo Sistema

# Gmail API
GMAIL_CLIENT_ID=your-gmail-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=https://control.pscielo.com/auth/gmail/callback

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your-instagram-business-account-id

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
CONTROL_PANEL_URL=http://control.pscielo.com

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
